# entlast.de — Environment-Variablen
# Kopieren nach /etc/entlast/env (App) und /etc/entlast/backup.env (Backup)

# --- App (in /etc/entlast/env) ---
SECRET_KEY=change-me-to-random-hex
ENCRYPTION_KEY=change-me-to-fernet-key

# --- Backup (in /etc/entlast/backup.env) ---
RESTIC_REPOSITORY=sftp:user@storagebox.de:/backups/entlast
RESTIC_PASSWORD=change-me

# --- Monitoring ---
ALERT_EMAIL=admin@example.com
