[Unit]
Description=entlast.de Backend
After=network.target

[Service]
Type=exec
User=entlast
WorkingDirectory=/opt/entlast
EnvironmentFile=/etc/entlast/env
ExecStart=/opt/entlast/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

# Hardening
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
ReadWritePaths=/opt/entlast/data
PrivateTmp=yes

[Install]
WantedBy=multi-user.target
